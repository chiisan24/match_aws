# ----------------------------------------------------------------------------
# AWS connection info (optional).
#
# When these are UNSET, the app runs entirely on mock adapters (Req 16.2, 17.3).
# When set, createGateway() will select the real AWS adapters (added later).
#
# Only VITE_-prefixed variables are exposed to the client bundle by Vite.
# Copy this file to `.env.local` for local development. NEVER commit real values.
# Configure the same variables in the Vercel project dashboard for deployment.
# ----------------------------------------------------------------------------

# AWS region for Bedrock / Location Service / DynamoDB / S3 / Translate
VITE_AWS_REGION=

# Identity pool / API endpoint used by the AWS gateway adapters (added later)
VITE_AWS_IDENTITY_POOL_ID=
VITE_AWS_API_ENDPOINT=

# Amazon Location Service map / place index names
VITE_AWS_LOCATION_MAP_NAME=
VITE_AWS_LOCATION_PLACE_INDEX=

# Set to "true" to force mock adapters even if the above are set (useful for demos)
VITE_FORCE_MOCK=

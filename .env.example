# ----------------------------------------------------------------------------
# AI backend configuration
#
# The AI features (チャット / プラン生成 / 翻訳 / 画像生成) run for real through
# the serverless functions under `api/`, which call Amazon Bedrock & Amazon
# Translate SERVER-SIDE. The browser never holds AWS credentials.
#
# - Leave VITE_AWS_API_ENDPOINT UNSET  -> the app runs entirely on mocks
#   (no AWS needed; safe default for demos / local dev / Vercel without AWS).
# - Set VITE_AWS_API_ENDPOINT=/api     -> the app calls the real AI backend.
#
# Only VITE_-prefixed variables are exposed to the client bundle by Vite.
# The AWS_* / BEDROCK_* variables below are SERVER-ONLY (no VITE_ prefix) and
# must be set in the Vercel project's Environment Variables (or .env.local).
# Copy this file to `.env.local` for local development. NEVER commit real values.
# ----------------------------------------------------------------------------

# ---- Client (browser) ------------------------------------------------------
# Base URL of the serverless API. Use "/api" for same-origin Vercel Functions.
VITE_AWS_API_ENDPOINT=

# Set to "true" to force mock adapters even if the endpoint is set (demos).
VITE_FORCE_MOCK=

# ---- Map (browser, no AWS / no key needed) ---------------------------------
# Set to "true" to render a real interactive map (MapLibre GL JS + OpenStreetMap)
# instead of the mock map surface. Independent of the AWS/AI settings above.
VITE_MAP_ENABLED=
# Optional: override the built-in OpenStreetMap raster style with a MapLibre
# style URL (public URL / public-scoped key only). Leave blank to use OSM.
VITE_MAP_STYLE_URL=

# ---- Server (Vercel Functions only — do NOT prefix with VITE_) -------------
# AWS credentials & region used by the api/ functions to call Bedrock/Translate.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional: override the Bedrock region just for model calls.
BEDROCK_REGION=

# Optional: override the default models.
#   Chat/plan: an Anthropic Claude model id available in your account.
#   Image:     Amazon Titan Image Generator.
BEDROCK_CHAT_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0
BEDROCK_IMAGE_MODEL_ID=amazon.titan-image-generator-v1

# ---- Reserved for future AWS adapters (map/auth/storage — still mocked) -----
VITE_AWS_IDENTITY_POOL_ID=
VITE_AWS_LOCATION_MAP_NAME=
VITE_AWS_LOCATION_PLACE_INDEX=
